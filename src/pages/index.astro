---
const buildDate = new Date().toISOString().slice(0, 10);
const baseUrl = import.meta.env.BASE_URL;
---

<html lang="cs">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
		<link rel="icon" href={`${baseUrl}favicon.ico`} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Rakli - nový web</title>
	</head>
	<body>
		<main>
			<p class="eyebrow">Testovací náhled</p>
			<h1>Rakli - nový web</h1>
			<p>
				Toto je první statický build nové verze webu. Slouží pouze pro ověření
				Astro projektu a deploye do oddělené složky <code>/_new/</code>.
			</p>
			<p class="status">Stávající WordPress web zůstává beze změny.</p>
			<p class="date">Build: {buildDate}</p>
		</main>
	</body>
</html>

<style>
	:root {
		color: #16312f;
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
			sans-serif;
		background: #f4f8f6;
	}

	body {
		margin: 0;
		min-height: 100vh;
		display: grid;
		place-items: center;
	}

	main {
		width: min(720px, calc(100vw - 32px));
		padding: 40px;
		background: #ffffff;
		border: 1px solid #d8e5df;
		border-radius: 8px;
		box-shadow: 0 24px 70px rgba(22, 49, 47, 0.12);
	}

	.eyebrow {
		margin: 0 0 12px;
		color: #34796f;
		font-size: 0.82rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	h1 {
		margin: 0;
		font-size: clamp(2rem, 6vw, 4rem);
		line-height: 1.05;
	}

	p {
		max-width: 58ch;
		font-size: 1.08rem;
		line-height: 1.7;
	}

	code {
		padding: 2px 6px;
		background: #edf5f1;
		border-radius: 4px;
	}

	.status {
		font-weight: 750;
	}

	.date {
		margin-bottom: 0;
		color: #5c726f;
		font-size: 0.95rem;
	}
</style>
