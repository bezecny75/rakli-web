---
import site from '../content/site.json';
import contact from '../content/contact.json';
import hours from '../content/hours.json';
import services from '../content/services.json';
import news from '../content/news.json';
import faq from '../content/faq.json';

const baseUrl = import.meta.env.BASE_URL;
const web3FormsKey = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY;
const primaryPhone = contact.phones[0];
const primaryEmail = contact.emails[0];
---

<html lang="cs">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
		<link rel="icon" href={`${baseUrl}favicon.ico`} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content={`${site.name} - ${site.tagline} v Českých Budějovicích.`}
		/>
		<title>{site.name} - {site.tagline}</title>
	</head>
	<body>
		<header class="site-header">
			<a class="brand" href="#top" aria-label="Úvod">
				<span>{site.name}</span>
				<small>{site.tagline}</small>
			</a>
			<nav aria-label="Hlavní navigace">
				<a href="#aktuality">Aktuality</a>
				<a href="#hodiny">Ordinační hodiny</a>
				<a href="#sluzby">Služby</a>
				<a href="#kontakt">Kontakt</a>
			</nav>
		</header>

		<main id="top">
			<section class="hero">
				<div class="hero-content">
					<p class="eyebrow">Testovací verze nového webu</p>
					<h1>{site.name}</h1>
					<p class="lead">{site.tagline}</p>
					<p>{site.intro}</p>
					<div class="hero-actions">
						<a class="button primary" href={`tel:${primaryPhone.replaceAll(' ', '')}`}>
							Zavolat do ordinace
						</a>
						<a class="button secondary" href={`mailto:${primaryEmail}`}>
							Napsat e-mail
						</a>
					</div>
				</div>

				<aside class="notice" aria-label="Provozní upozornění">
					<strong>Aktuální upozornění</strong>
					<p>{site.notice}</p>
					<p class="muted">
						Stávající WordPress web zatím zůstává beze změny.
					</p>
				</aside>
			</section>

			<section id="aktuality" class="section">
				<div class="section-head">
					<p class="eyebrow">Informace pro pacienty</p>
					<h2>Aktuality</h2>
				</div>

				<div class="news-list">
					{news.map((item) => (
						<article class="card">
							<time datetime={item.date}>{item.date}</time>
							<h3>{item.title}</h3>
							<p>{item.body}</p>
						</article>
					))}
				</div>
			</section>

			<section id="hodiny" class="section split">
				<div class="section-head">
					<p class="eyebrow">Provoz ordinace</p>
					<h2>Ordinační hodiny</h2>
					<p>
						Časy vycházejí z aktuálně dostupného webu. Před návštěvou ordinace
						doporučujeme telefonické ověření.
					</p>
				</div>

				<div class="hours">
					{hours.map((day) => (
						<div class="hours-row">
							<h3>{day.day}</h3>
							<ul>
								{day.items.map((item) => <li>{item}</li>)}
							</ul>
						</div>
					))}
				</div>
			</section>

			<section id="sluzby" class="section">
				<div class="section-head">
					<p class="eyebrow">Zdravotní péče</p>
					<h2>Služby ordinace</h2>
				</div>

				<div class="service-grid">
					{services.map((service) => (
						<article class="card">
							<h3>{service.title}</h3>
							<p>{service.description}</p>
						</article>
					))}
				</div>
			</section>

			<section class="section split">
				<div class="section-head">
					<p class="eyebrow">Časté dotazy</p>
					<h2>FAQ</h2>
				</div>

				<div class="faq-list">
					{faq.map((item) => (
						<details>
							<summary>{item.question}</summary>
							<p>{item.answer}</p>
						</details>
					))}
				</div>
			</section>

			<section id="kontakt" class="section contact-section">
				<div class="section-head">
					<p class="eyebrow">Kontakt</p>
					<h2>Objednání a dotazy</h2>
				</div>

				<div class="contact-grid">
					<div class="contact-card">
						<h3>{site.name}</h3>
						<p>{site.doctor}</p>
						<address>
							{contact.address.street}<br />
							{contact.address.city}
						</address>
						<ul class="contact-list">
							{contact.phones.map((phone) => (
								<li><a href={`tel:${phone.replaceAll(' ', '')}`}>{phone}</a></li>
							))}
							{contact.emails.map((email) => (
								<li><a href={`mailto:${email}`}>{email}</a></li>
							))}
						</ul>
					</div>

					<div class="contact-card">
						<h3>Kontaktní formulář</h3>
						{web3FormsKey ? (
							<form action="https://api.web3forms.com/submit" method="POST">
								<input type="hidden" name="access_key" value={web3FormsKey} />
								<label>
									Jméno
									<input name="name" autocomplete="name" required />
								</label>
								<label>
									E-mail
									<input type="email" name="email" autocomplete="email" required />
								</label>
								<label>
									Zpráva
									<textarea name="message" rows="5" required></textarea>
								</label>
								<button class="button primary" type="submit">Odeslat</button>
							</form>
						) : (
							<p>
								Formulář bude aktivován po doplnění Web3Forms klíče. Do té doby
								prosím použijte e-mail <a href={`mailto:${primaryEmail}`}>{primaryEmail}</a>.
							</p>
						)}
					</div>
				</div>
			</section>
		</main>
	</body>
</html>

<style>
	:root {
		--ink: #173331;
		--muted: #60716f;
		--line: #d8e5df;
		--surface: #ffffff;
		--soft: #f3f8f5;
		--brand: #267568;
		--brand-dark: #174e47;
		--accent: #d89b35;
		color: var(--ink);
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
			sans-serif;
		background: var(--soft);
		scroll-behavior: smooth;
	}

	* {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		min-width: 320px;
	}

	a {
		color: var(--brand-dark);
	}

	.site-header {
		position: sticky;
		top: 0;
		z-index: 10;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		padding: 16px clamp(18px, 4vw, 56px);
		background: rgba(255, 255, 255, 0.94);
		border-bottom: 1px solid var(--line);
		backdrop-filter: blur(16px);
	}

	.brand {
		display: grid;
		gap: 2px;
		text-decoration: none;
	}

	.brand span {
		font-weight: 900;
	}

	.brand small,
	.muted,
	time {
		color: var(--muted);
	}

	nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 14px;
		font-size: 0.95rem;
	}

	nav a {
		text-decoration: none;
		font-weight: 750;
	}

	main {
		width: min(1180px, calc(100vw - 32px));
		margin: 0 auto;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.6fr) minmax(280px, 0.8fr);
		gap: 28px;
		align-items: stretch;
		padding: 64px 0 36px;
	}

	.hero-content,
	.notice,
	.card,
	.contact-card,
	details {
		background: var(--surface);
		border: 1px solid var(--line);
		border-radius: 8px;
		box-shadow: 0 18px 55px rgba(23, 51, 49, 0.08);
	}

	.hero-content {
		padding: clamp(28px, 5vw, 56px);
	}

	.notice {
		align-self: stretch;
		padding: 28px;
		border-color: rgba(216, 155, 53, 0.45);
		background: #fff9ee;
	}

	.eyebrow {
		margin: 0 0 10px;
		color: var(--brand);
		font-size: 0.82rem;
		font-weight: 850;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	h1 {
		margin-bottom: 10px;
		font-size: clamp(2.5rem, 7vw, 5.4rem);
		line-height: 0.96;
	}

	h2 {
		font-size: clamp(1.9rem, 4vw, 3rem);
		line-height: 1.08;
	}

	h3 {
		margin-bottom: 10px;
		font-size: 1.15rem;
	}

	p,
	li,
	label,
	input,
	textarea {
		font-size: 1rem;
		line-height: 1.65;
	}

	.lead {
		color: var(--brand-dark);
		font-size: clamp(1.2rem, 2.4vw, 1.55rem);
		font-weight: 750;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 28px;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 44px;
		padding: 10px 18px;
		border: 1px solid var(--brand);
		border-radius: 6px;
		font-weight: 800;
		text-decoration: none;
	}

	.button.primary {
		color: #ffffff;
		background: var(--brand);
	}

	.button.secondary {
		color: var(--brand-dark);
		background: #ffffff;
	}

	.section {
		padding: 42px 0;
	}

	.section-head {
		max-width: 720px;
		margin-bottom: 24px;
	}

	.news-list,
	.service-grid,
	.contact-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 18px;
	}

	.card,
	.contact-card {
		padding: 24px;
	}

	.split {
		display: grid;
		grid-template-columns: minmax(0, 0.75fr) minmax(0, 1.25fr);
		gap: 28px;
		align-items: start;
	}

	.hours {
		display: grid;
		gap: 10px;
	}

	.hours-row {
		display: grid;
		grid-template-columns: 150px minmax(0, 1fr);
		gap: 16px;
		padding: 16px 0;
		border-bottom: 1px solid var(--line);
	}

	.hours-row h3,
	.hours-row ul {
		margin: 0;
	}

	.hours-row ul,
	.contact-list {
		padding-left: 18px;
	}

	details {
		padding: 18px 20px;
		margin-bottom: 12px;
	}

	summary {
		cursor: pointer;
		font-weight: 850;
	}

	address {
		font-style: normal;
		line-height: 1.7;
	}

	form {
		display: grid;
		gap: 14px;
	}

	label {
		display: grid;
		gap: 6px;
		font-weight: 750;
	}

	input,
	textarea {
		width: 100%;
		padding: 11px 12px;
		border: 1px solid var(--line);
		border-radius: 6px;
		font: inherit;
	}

	@media (max-width: 820px) {
		.site-header,
		.hero,
		.split,
		.news-list,
		.service-grid,
		.contact-grid,
		.hours-row {
			grid-template-columns: 1fr;
		}

		.site-header {
			position: static;
			align-items: flex-start;
		}

		nav {
			justify-content: flex-start;
		}

		.hero {
			padding-top: 32px;
		}
	}
</style>
