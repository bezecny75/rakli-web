---
import site from '../content/site.json';
import contact from '../content/contact.json';
import hours from '../content/hours.json';
import services from '../content/services.json';
import news from '../content/news.json';
import faq from '../content/faq.json';
import pricing from '../content/pricing.json';
import about from '../content/about.json';
import ordering from '../content/ordering.json';
import vaccination from '../content/vaccination.json';
import alert from '../content/alert.json';
import status from '../content/status.json';

const baseUrl = import.meta.env.BASE_URL;
const web3FormsKey = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY;
const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? 'https://rakli.cz';
const formRedirectUrl = new URL(`${baseUrl}dekujeme/`, siteUrl).toString();
const pricingUrl = `${baseUrl}cenik/`;
const primaryPhone = contact.phones[0];
const primaryEmail = contact.emails[0];
const telHref = primaryPhone.replaceAll(' ', '');
const today = new Date().toISOString().split('T')[0];
const alertVisible = alert.active && (!alert.expires || alert.expires >= today);
const insuranceBadges = ['111 VZP', '201 VoZP', '207 OZP', '211 ZPMV', '205 ČPZP'];
const dayIndexes = { 'Pondělí': 1, 'Úterý': 2, 'Středa': 3, 'Čtvrtek': 4, 'Pátek': 5, 'Sobota': 6, 'Neděle': 0 };
const hoursForClient = hours.map((day) => ({ ...day, dayIndex: dayIndexes[day.day] ?? null }));
const formatCzechDate = (value) => {
	const [year, month, day] = value.split('-');
	return `${day}.${month}.${year}`;
};
const trustItems = [
	'✓ Smluvní pojišťovny VZP, VoZP, OZP, ZPMV, ČPZP',
	'✓ EKG & Holter v ordinaci',
	'✓ E-recepty pro stabilní pacienty',
	'✓ Závodní péče pro firmy',
];
const workflowSteps = [
	'Zavolejte nám nebo napište přes formulář.',
	'Přijďte v domluvené ordinační době.',
	'Ošetříme vás a domluvíme další postup.',
	'E-recept pošleme na mobil nebo e-mail.',
];
const serviceIcons = {
	'Preventivní prohlídky': `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 21s-7-4.5-9-10a5.5 5.5 0 0 1 9-6 5.5 5.5 0 0 1 9 6c-2 5.5-9 10-9 10Z"/><path d="M8 12h3l1-3 2 6 1-3h3"/></svg>`,
	'E-Recepty & Posudky': `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M7 3h7l4 4v14H7z"/><path d="M14 3v5h5"/><path d="M9 13h6M9 17h5"/></svg>`,
	'CRP a INR testy': `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M10 3h4v5l4 8a4 4 0 0 1-3.6 5.7H9.6A4 4 0 0 1 6 16l4-8z"/><path d="M8 16h8"/></svg>`,
	'EKG a Tlakový Holter': `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 13h4l2-5 4 10 2-5h4"/><path d="M5 5h14v14H5z"/></svg>`,
	'Očkování': `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M15 4l5 5-9 9-5-5z"/><path d="M4 20l4-4M14 5l5 5M7 10l3 3"/></svg>`,
	'Závodní péče': `<svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 6V4h6v2h4v14H5V6z"/><path d="M10 13h4M12 11v4"/></svg>`,
};
const formSubjects = [
	'Žádost o e-recept (stálá medikace)',
	'Objednání na prohlídku',
	'Výpis ze zdravotní dokumentace',
	'Jiný dotaz',
];
---

<html lang="cs">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
		<link rel="icon" href={`${baseUrl}favicon.ico`} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content={`${site.name} - ${site.tagline} v Českých Budějovicích.`}
		/>
		<title>{site.name} - {site.tagline}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		{alertVisible && (
			<div class={`alert-bar alert-bar--${alert.type}`}>
				<div class="alert-bar__inner">
					<span class="alert-bar__icon" aria-hidden="true">
						{alert.type === 'urgent' ? '🚨' : alert.type === 'warning' ? '⚠️' : 'ℹ️'}
					</span>
					<span class="alert-bar__message">{alert.message}</span>
				</div>
			</div>
		)}

		<div class="top-bar">
			<div class="top-bar__inner">
				<a href={`tel:${telHref}`}>{primaryPhone}</a>
				<strong>{site.badge}</strong>
				<div class="top-bar__badges" aria-label="Smluvní pojišťovny">
					{insuranceBadges.map((badge) => <span>{badge}</span>)}
				</div>
			</div>
		</div>

		<header class="site-header">
			<a class="brand" href="#top" aria-label="Úvod">
				<span>{site.name}</span>
				<small>{site.tagline}</small>
			</a>

			<input class="nav-toggle" id="nav-toggle" type="checkbox" aria-label="Otevřít menu" />
			<label class="hamburger" for="nav-toggle" aria-hidden="true">
				<span></span>
				<span></span>
				<span></span>
			</label>

			<nav aria-label="Hlavní navigace">
				<a href="#sluzby">Služby</a>
				<a href="#hodiny">Ordinační hodiny</a>
				<a href={pricingUrl}>Ceník</a>
				<a href="#faq">FAQ</a>
				<a href="#kontakt">Kontakt</a>
				<a class="nav-cta" href="#formular">Objednat</a>
			</nav>
		</header>

		<main id="top">
			<section class="hero">
				<div class="hero__inner">
					<div class="hero-content">
						<div class="hero-kicker">
							<span class={`status-badge status-badge--${status.state}`} id="status-badge" data-default-state={status.state} data-default-label={status.label}>
								<span class="status-badge__dot"></span>
								<span id="status-badge-label">{status.label}</span>
								{status.note && <span class="status-badge__note"> — {status.note}</span>}
							</span>
							<span>{site.doctor}</span>
						</div>
						<div class="hero-alert">
							<strong>Aktuální upozornění</strong>
							<p>{site.notice}</p>
						</div>
						<h1>{site.heroTitle}</h1>
						<p class="lead">{site.intro}</p>
						<div class="hero-actions">
							<a class="button primary" href={site.buttonUrl}>{site.buttonText}</a>
							<a class="button secondary" href={`mailto:${primaryEmail}`}>Napsat e-mail</a>
						</div>
					</div>

					<div class="hero-photo" aria-label="Ilustrační karta ordinace">
						<span>🩺</span>
						<p>Moderní ordinace praktického lékaře v Českých Budějovicích</p>
					</div>
				</div>
			</section>

			<section class="trust-bar" aria-label="Rychlé výhody ordinace">
				<div class="trust-bar__inner">
					{trustItems.map((item) => <span>{item}</span>)}
				</div>
			</section>

			<section class="section workflow-section">
				<div class="section-head centered">
					<p class="section-label">Pro nové pacienty</p>
					<h2>Jak to u nás funguje</h2>
				</div>
				<div class="workflow-grid">
					{workflowSteps.map((step, index) => (
						<div class="workflow-step">
							<div class="step-number">{index + 1}</div>
							<p>{step}</p>
						</div>
					))}
				</div>
			</section>

			<section id="aktuality" class="section news-section">
				<div class="section-head centered">
					<p class="section-label">Informace pro pacienty</p>
					<h2>Aktuality</h2>
				</div>

				<div class="news-list">
					{news.map((item) => (
						<article class="news-card">
							<time datetime={item.date}>{formatCzechDate(item.date)}</time>
							<h3>{item.title}</h3>
							<p>{item.body}</p>
						</article>
					))}
				</div>
			</section>

			<section id="sluzby" class="section services-section">
				<span id="services" class="anchor-alias"></span>
				<div class="section-head centered">
					<p class="section-label">Zdravotní péče</p>
					<h2>Služby ordinace</h2>
				</div>

				<div class="service-grid">
					{services.map((service) => (
						<article class="service-card">
							<span class="service-icon" aria-hidden="true" set:html={serviceIcons[service.title] ?? service.icon}></span>
							<h3>{service.title}</h3>
							<p>{service.description}</p>
						</article>
					))}
				</div>
			</section>

			<section id="objednavani" class="section ordering-section split-section">
				<div class="section-head">
					<p class="section-label">Objednání</p>
					<h2>{ordering.title}</h2>
					<p>{ordering.body}</p>
				</div>
				<div class="info-list">
					{ordering.notes.map((note) => <div class="info-row">{note}</div>)}
				</div>
			</section>

			<section id="hodiny" class="section hours-section">
				<span id="ordinacni-hodiny" class="anchor-alias"></span>
				<div class="section-head centered">
					<p class="section-label">Provoz ordinace</p>
					<h2>Ordinační hodiny</h2>
					<p>Před návštěvou ordinace doporučujeme telefonické ověření.</p>
				</div>

				<div class="hours-grid">
					{hours.map((day) => (
						<article class="hours-card" data-day-index={dayIndexes[day.day] ?? ''}>
							<h3>{day.day}</h3>
							<div>
								{day.items.map((item) => <p>{item}</p>)}
							</div>
						</article>
					))}
				</div>
			</section>

			<section id="cenik" class="section pricing-section pricing-teaser">
				<div class="section-head centered">
					<p class="section-label">Placené úkony</p>
					<h2>Ceník</h2>
					<p>Kompletní ceník placených výkonů je nově na samostatné přehledné stránce.</p>
				</div>
				<div class="pricing-teaser__box">
					<div>
						<strong>Platnost od 01.01.2026</strong>
						<p>Úkony nehrazené zdravotními pojišťovnami.</p>
					</div>
					<a class="button secondary" href={pricingUrl}>Otevřít celý ceník</a>
				</div>
			</section>

			<section id="faq" class="section faq-section">
				<div class="section-head centered">
					<p class="section-label">Časté dotazy</p>
					<h2>FAQ</h2>
				</div>
				<div class="faq-list">
					{faq.map((item) => (
						<details>
							<summary>{item.question}</summary>
							<div>{item.answer}</div>
						</details>
					))}
				</div>
			</section>

			<section id="ockovani" class="section vaccination-section split-section">
				<div class="section-head">
					<p class="section-label">Prevence</p>
					<h2>{vaccination.title}</h2>
					<p>{vaccination.body}</p>
				</div>
				<div class="info-list">
					{vaccination.items.map((item) => <div class="info-row">{item}</div>)}
				</div>
			</section>

			<section id="kontakt" class="section contact-section">
				<span id="contact" class="anchor-alias"></span>
				<div class="section-head centered">
					<p class="section-label">Kontakt</p>
					<h2>Objednání a dotazy</h2>
				</div>

				<div class="contact-grid">
					<div id="onas" class="contact-card">
						<h3>{about.title}</h3>
						<p>{about.body}</p>
						<ul class="team-list">
							{about.team.map((person) => <li>{person}</li>)}
						</ul>
					</div>

					<div class="contact-card">
						<h3>{site.name}</h3>
						<p>{contact.note}</p>
						<address>
							{contact.address.street}<br />
							{contact.address.city}
						</address>
						<ul class="contact-list">
							{contact.phones.map((phone) => (
								<li><a href={`tel:${phone.replaceAll(' ', '')}`}>{phone}</a></li>
							))}
							{contact.emails.map((email) => (
								<li><a href={`mailto:${email}`}>{email}</a></li>
							))}
						</ul>
						<iframe
							title="Mapa ordinace Rakli s.r.o."
							src="https://www.google.com/maps?q=K.%20%C5%A0af%C3%A1%C5%99e%20887%2F64%2C%20%C4%8Cesk%C3%A9%20Bud%C4%9Bjovice&output=embed"
							loading="lazy"
						></iframe>
					</div>

					<div id="formular" class="contact-card form-card">
						<h3>Kontaktní formulář</h3>
						{web3FormsKey ? (
							<form action="https://api.web3forms.com/submit" method="POST">
								<input type="hidden" name="access_key" value={web3FormsKey} />
								<input type="hidden" name="from_name" value="Web rakli.cz" />
								<input type="hidden" name="redirect" value={formRedirectUrl} />
								<input type="checkbox" name="botcheck" class="sr-only" tabindex="-1" autocomplete="off" />
								<label>
									Jméno
									<input name="name" autocomplete="name" required />
								</label>
								<label>
									E-mail
									<input type="email" name="email" autocomplete="email" required />
								</label>
								<label>
									Telefon
									<input name="phone" autocomplete="tel" />
								</label>
								<label>
									Rok narození
									<input name="birth_year" inputmode="numeric" pattern="[0-9]{4}" placeholder="např. 1975" />
								</label>
								<label>
									Předmět zprávy
									<select name="subject" required>
										{formSubjects.map((subject) => <option value={subject}>{subject}</option>)}
									</select>
								</label>
								<label>
									Zpráva
									<textarea name="message" rows="5" required></textarea>
								</label>
								<p class="form-note">
									Do formuláře neposílejte akutní zdravotní potíže. V urgentních případech volejte záchrannou službu nebo ordinaci telefonicky.
								</p>
								<button class="button primary" type="submit">Odeslat</button>
							</form>
						) : (
							<p>
								Formulář bude aktivován po doplnění Web3Forms klíče. Do té doby prosím použijte e-mail <a href={`mailto:${primaryEmail}`}>{primaryEmail}</a>.
							</p>
						)}
					</div>
				</div>
			</section>
		</main>

		<footer class="custom-footer">
			<div class="footer-container">
				<div class="footer-grid">
					<div class="footer-brand">
						<a href="#top" class="footer-logo">{site.name}</a>
						<p>Poskytujeme kvalitní primární péči založenou na důvěře a odbornosti.</p>
					</div>

					<div class="footer-links">
						<h4>Rychlé odkazy</h4>
						<a href="#top">Úvod</a>
						<a href="#services">Služby</a>
						<a href="#ordinacni-hodiny">Ordinační hodiny</a>
						<a href={pricingUrl}>Ceník</a>
						<a href="#contact">Kontakt</a>
					</div>

					<div class="footer-links">
						<h4>Kontakt</h4>
						<a href={`tel:${telHref}`}>{primaryPhone}</a>
						<a href={`mailto:${primaryEmail}`}>{primaryEmail}</a>
						<div class="footer-address">
							{contact.address.street}<br />
							{contact.address.city}
						</div>
					</div>

					<div class="footer-insurance">
						<h4>Pojišťovny</h4>
						<div class="insurance-grid">
							{insuranceBadges.map((badge) => <span>{badge}</span>)}
						</div>
					</div>
				</div>

				<div class="footer-bottom">
					<div>© 2026 {site.name} Všechna práva vyhrazena.</div>
					<div>Praktický lékař pro dospělé · České Budějovice</div>
				</div>
			</div>
		</footer>

		<a class="back-to-top" href="#top" aria-label="Zpět nahoru">↑</a>

		<script type="application/json" id="hours-data" set:html={JSON.stringify(hoursForClient)}></script>
		<script type="application/json" id="alert-data" set:html={JSON.stringify({ active: alert.active, type: alert.type, message: alert.message, expires: alert.expires })}></script>
		<script>
			const badge = document.getElementById('status-badge');
			const badgeLabel = document.getElementById('status-badge-label');
			const hoursData = JSON.parse(document.getElementById('hours-data')?.textContent || '[]');
			const alertData = JSON.parse(document.getElementById('alert-data')?.textContent || '{}');
			const now = new Date();
			const todayIndex = now.getDay();
			const todayCard = document.querySelector(`[data-day-index="${todayIndex}"]`);
			if (todayCard) todayCard.classList.add('is-highlighted');

			function minutesFromTime(value) {
				const [hours, minutes] = value.split(':').map(Number);
				return hours * 60 + minutes;
			}

			function isOpenNow(day) {
				if (!day) return false;
				const current = now.getHours() * 60 + now.getMinutes();
				return day.items.some((item) => {
					const match = item.match(/(\d{1,2}:\d{2})\s*-\s*(\d{1,2}:\d{2})/);
					if (!match) return false;
					return current >= minutesFromTime(match[1]) && current <= minutesFromTime(match[2]);
				});
			}

			function setStatus(state, label) {
				if (!badge || !badgeLabel) return;
				badge.className = `status-badge status-badge--${state}`;
				badgeLabel.textContent = label;
			}

			const alertExpiresOk = !alertData.expires || alertData.expires >= now.toISOString().slice(0, 10);
			const defaultState = badge?.dataset.defaultState || 'open';
			const defaultLabel = badge?.dataset.defaultLabel || 'Dnes otevřeno';
			if (defaultState !== 'open') {
				setStatus(defaultState, defaultLabel);
			} else if (alertData.active && alertExpiresOk && alertData.type === 'urgent') {
				setStatus('closed', 'Dnes zavřeno');
			} else if (alertData.active && alertExpiresOk && alertData.type === 'warning') {
				setStatus('limited', 'Omezený provoz');
			} else {
				const day = hoursData.find((item) => item.dayIndex === todayIndex);
				const open = isOpenNow(day);
				setStatus(open ? 'open' : 'closed', open ? 'Právě otevřeno' : 'Právě zavřeno');
			}
		</script>
	</body>
</html>

<style>
	:root {
		--color-primary: #0f4c75;
		--color-primary-light: #e3eff7;
		--color-primary-mid: #1b6ca8;
		--color-accent: #27ae60;
		--color-accent-dark: #1e8449;
		--color-warm: #f0f4f8;
		--color-text: #1a202c;
		--color-text-muted: #718096;
		--color-border: #e2e8f0;
		--shadow-card: 0 2px 12px rgba(15, 76, 117, 0.10);
		--shadow-hover: 0 8px 30px rgba(15, 76, 117, 0.18);
		--radius-card: 12px;
		--radius-pill: 50px;
		--transition: all 0.22s cubic-bezier(0.4, 0, 0.2, 1);
		font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		color: var(--color-text);
		background: white;
		scroll-behavior: smooth;
	}

	* { box-sizing: border-box; }
	body { margin: 0; min-width: 320px; background: white; color: var(--color-text); }
	a { color: inherit; text-decoration: none; }
	p { line-height: 1.7; }

	.alert-bar { width: 100%; padding: 0.65rem 1.5rem; font-size: 0.9rem; font-weight: 500; text-align: center; }
	.alert-bar__inner { max-width: 1100px; margin: 0 auto; display: flex; align-items: center; justify-content: center; gap: 0.5rem; }
	.alert-bar--info { background: #dbeafe; color: #1e40af; }
	.alert-bar--warning { background: #fef3c7; color: #92400e; }
	.alert-bar--urgent { background: #fee2e2; color: #991b1b; }

	.top-bar { position: sticky; top: 0; z-index: 40; height: 40px; background: var(--color-primary); color: white; font-size: 0.85rem; }
	.top-bar__inner { max-width: 1100px; height: 100%; margin: 0 auto; padding: 0 1.5rem; display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
	.top-bar strong { color: #fecaca; font-weight: 800; letter-spacing: 0.02em; }
	.top-bar__badges { display: flex; gap: 0.35rem; flex-wrap: wrap; justify-content: flex-end; }
	.top-bar__badges span { border: 1px solid rgba(255, 255, 255, 0.28); border-radius: 999px; padding: 0.12rem 0.45rem; font-size: 0.75rem; }

	.site-header { position: sticky; top: 40px; z-index: 35; height: 68px; background: white; box-shadow: 0 1px 0 var(--color-border), var(--shadow-card); display: flex; align-items: center; justify-content: space-between; padding: 0 1.5rem; }
	.site-header .brand { display: grid; gap: 0.1rem; color: var(--color-primary); }
	.brand span { font-size: 1.28rem; font-weight: 800; letter-spacing: -0.03em; }
	.brand small { color: var(--color-text-muted); font-size: 0.76rem; font-weight: 500; }
	nav { display: flex; align-items: center; gap: 1.35rem; }
	nav a { position: relative; color: var(--color-text); font-size: 0.94rem; font-weight: 500; letter-spacing: 0.01em; transition: var(--transition); }
	nav a::after { content: ""; position: absolute; left: 0; right: 0; bottom: -0.35rem; height: 2px; background: var(--color-primary-mid); transform: scaleX(0); transform-origin: center; transition: transform 0.2s ease; }
	nav a:hover { color: var(--color-primary-mid); }
	nav a:hover::after { transform: scaleX(1); }
