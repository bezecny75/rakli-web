---
import site from '../content/site.json';
import contact from '../content/contact.json';
import hours from '../content/hours.json';
import services from '../content/services.json';
import news from '../content/news.json';
import faq from '../content/faq.json';
import pricing from '../content/pricing.json';
import about from '../content/about.json';
import ordering from '../content/ordering.json';
import vaccination from '../content/vaccination.json';

const baseUrl = import.meta.env.BASE_URL;
const web3FormsKey = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY;
const siteUrl = import.meta.env.PUBLIC_SITE_URL ?? 'https://rakli.cz';
const formRedirectUrl = new URL(`${baseUrl}dekujeme/`, siteUrl).toString();
const primaryPhone = contact.phones[0];
const primaryEmail = contact.emails[0];
---

<html lang="cs">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
		<link rel="icon" href={`${baseUrl}favicon.ico`} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta
			name="description"
			content={`${site.name} - ${site.tagline} v Českých Budějovicích.`}
		/>
		<title>{site.name} - {site.tagline}</title>
		<script src="https://code.iconify.design/iconify-icon/1.0.8/iconify-icon.min.js"></script>
	</head>
	<body>
		<header class="site-header">
			<a class="brand" href="#top" aria-label="Úvod">
				<span>{site.name}</span>
				<small>{site.tagline}</small>
			</a>
			<nav aria-label="Hlavní navigace">
				<a href="#sluzby">Služby</a>
				<a href="#hodiny">Ordinační hodiny</a>
				<a href="#cenik">Ceník</a>
				<a href="#kontakt">Kontakt</a>
				<a class="nav-cta" href="#formular">Objednat</a>
			</nav>
		</header>

		<main id="top">
			<section class="hero">
				<div class="hero-content">
					<p class="eyebrow">{site.badge}</p>
					<h1>{site.heroTitle}</h1>
					<p class="lead">{site.tagline}</p>
					<p>{site.intro}</p>
					<div class="hero-actions">
						<a class="button primary" href={site.buttonUrl}>
							{site.buttonText}
						</a>
						<a class="button secondary" href={`mailto:${primaryEmail}`}>
							Napsat e-mail
						</a>
					</div>
				</div>

				<aside class="notice" aria-label="Provozní upozornění">
					<strong>Aktuální upozornění</strong>
					<p>{site.notice}</p>
					<p class="muted">
						Stávající WordPress web zatím zůstává beze změny.
					</p>
				</aside>
			</section>

			<section id="sluzby" class="section">
				<span id="services" class="anchor-alias"></span>
				<div class="section-head">
					<p class="eyebrow">Zdravotní péče</p>
					<h2>Služby</h2>
				</div>

				<div class="service-grid">
					{services.map((service) => (
						<article class="card">
							<span class="service-icon" aria-hidden="true">{service.icon}</span>
							<h3>{service.title}</h3>
							<p>{service.description}</p>
						</article>
					))}
				</div>
			</section>

			<section id="objednavani" class="section split">
				<div class="section-head">
					<p class="eyebrow">Objednání</p>
					<h2>{ordering.title}</h2>
					<p>{ordering.body}</p>
				</div>

				<div class="info-list">
					{ordering.notes.map((note) => (
						<div class="info-row">{note}</div>
					))}
				</div>
			</section>

			<section class="section split">
				<div class="section-head">
					<p class="eyebrow">Časté dotazy</p>
					<h2>FAQ</h2>
				</div>

				<div class="faq-list">
					{faq.map((item) => (
						<details>
							<summary>{item.question}</summary>
							<p>{item.answer}</p>
						</details>
					))}
				</div>
			</section>

			<section id="ockovani" class="section split">
				<div class="section-head">
					<p class="eyebrow">Prevence</p>
					<h2>{vaccination.title}</h2>
					<p>{vaccination.body}</p>
				</div>

				<div class="info-list">
					{vaccination.items.map((item) => (
						<div class="info-row">{item}</div>
					))}
				</div>
			</section>

			<section id="aktuality" class="section">
				<div class="section-head">
					<p class="eyebrow">Informace pro pacienty</p>
					<h2>Aktuality</h2>
				</div>

				<div class="news-list">
					{news.map((item) => (
						<article class="card">
							<time datetime={item.date}>{item.date}</time>
							<h3>{item.title}</h3>
							<p>{item.body}</p>
						</article>
					))}
				</div>
			</section>

			<section id="hodiny" class="section split">
				<span id="ordinacni-hodiny" class="anchor-alias"></span>
				<div class="section-head">
					<p class="eyebrow">Provoz ordinace</p>
					<h2>Ordinační hodiny</h2>
					<p>
						Časy vycházejí z aktuálně dostupného webu. Před návštěvou ordinace
						doporučujeme telefonické ověření.
					</p>
				</div>

				<div class="hours">
					{hours.map((day) => (
						<div class="hours-row">
							<h3>{day.day}</h3>
							<ul>
								{day.items.map((item) => <li>{item}</li>)}
							</ul>
						</div>
					))}
				</div>
			</section>

			<section id="cenik" class="section">
				<div class="section-head">
					<p class="eyebrow">Placené úkony</p>
					<h2>Ceník</h2>
					<p>Platnost od 1.1.2026. Jedná se o úkony nehrazené zdravotními pojišťovnami.</p>
				</div>

				<div class="price-list">
					{pricing.map((item) => (
						<div class="price-row">
							<div>
								<strong>{item.title}</strong>
								{item.note && <p>{item.note}</p>}
							</div>
							<span>{item.price}</span>
						</div>
					))}
				</div>
			</section>

			<section id="kontakt" class="section contact-section">
				<span id="contact" class="anchor-alias"></span>
				<div class="section-head">
					<p class="eyebrow">Kontakt</p>
					<h2>Objednání a dotazy</h2>
				</div>

				<div class="contact-grid">
					<div id="onas" class="contact-card">
						<h3>{about.title}</h3>
						<p>{about.body}</p>
						<ul class="team-list">
							{about.team.map((person) => <li>{person}</li>)}
						</ul>
					</div>

					<div class="contact-card">
						<h3>{site.name}</h3>
						<p>{contact.note}</p>
						<address>
							{contact.address.street}<br />
							{contact.address.city}
						</address>
						<ul class="contact-list">
							{contact.phones.map((phone) => (
								<li><a href={`tel:${phone.replaceAll(' ', '')}`}>{phone}</a></li>
							))}
							{contact.emails.map((email) => (
								<li><a href={`mailto:${email}`}>{email}</a></li>
							))}
						</ul>
					</div>

					<div id="formular" class="contact-card">
						<h3>Kontaktní formulář</h3>
						{web3FormsKey ? (
							<form action="https://api.web3forms.com/submit" method="POST">
								<input type="hidden" name="access_key" value={web3FormsKey} />
								<input type="hidden" name="subject" value="Nová zpráva z webu Rakli s.r.o." />
								<input type="hidden" name="from_name" value="Web rakli.cz" />
								<input type="hidden" name="redirect" value={formRedirectUrl} />
								<input type="checkbox" name="botcheck" class="sr-only" tabindex="-1" autocomplete="off" />
								<label>
									Jméno
									<input name="name" autocomplete="name" required />
								</label>
								<label>
									E-mail
									<input type="email" name="email" autocomplete="email" required />
								</label>
								<label>
									Telefon
									<input name="phone" autocomplete="tel" />
								</label>
								<label>
									Zpráva
									<textarea name="message" rows="5" required></textarea>
								</label>
								<p class="form-note">
									Do formuláře neposílejte akutní zdravotní potíže. V urgentních
									případech volejte záchrannou službu nebo ordinaci telefonicky.
								</p>
								<button class="button primary" type="submit">Odeslat</button>
							</form>
						) : (
							<p>
								Formulář bude aktivován po doplnění Web3Forms klíče. Do té doby
								prosím použijte e-mail <a href={`mailto:${primaryEmail}`}>{primaryEmail}</a>.
							</p>
						)}
					</div>
				</div>
			</section>
		</main>

		<footer class="custom-footer">
			<div class="footer-container">
				<div class="footer-grid">
					<div class="footer-brand">
						<a href="#top" class="footer-logo">
							<div class="footer-logo-icon">
								<iconify-icon icon="solar:health-linear" width="14"></iconify-icon>
							</div>
							<span>Rakli s.r.o.</span>
						</a>
						<p>
							Poskytujeme kvalitní primární péči založenou na důvěře a odbornosti.
							Smluvní partner všech zdravotních pojišťoven.
						</p>
					</div>

					<div class="footer-links">
						<h4>Odkazy</h4>
						<a href="#top">Úvod</a>
						<a href="#services">Služby</a>
						<a href="#ordinacni-hodiny">Ordinační hodiny</a>
						<a href="https://www.rakli.cz/cenik">Ceník placených úkonů</a>
						<a href="#contact">Kontakt</a>
					</div>

					<div class="footer-links">
						<h4>Kontakt</h4>
						<a href="tel:+420 123 456 789">+420 123 456 789</a>
						<a href="mailto:info@rakli.cz">info@rakli.cz</a>
						<div class="footer-address">
							K. Šafáře 887/64<br />
							České Budějovice
						</div>
					</div>

					<div class="footer-insurance">
						<h4>Pojišťovny</h4>
						<div class="insurance-grid">
							<span>111 VZP</span>
							<span>201 VoZP</span>
							<span>207 OZP</span>
							<span>211 ZPMV</span>
							<span>205 ČPZP</span>
						</div>
					</div>
				</div>

				<div class="footer-bottom">
					<div class="footer-copy">
						© 2026 {site.name} Všechna práva vyhrazena.
					</div>

					<div class="footer-socials">
						<a href="#">
							<iconify-icon icon="solar:facebook-linear" width="18"></iconify-icon>
						</a>
						<a href="#">
							<iconify-icon icon="solar:instagram-linear" width="18"></iconify-icon>
						</a>
					</div>
				</div>
			</div>
		</footer>
	</body>
</html>

<style>
	:root {
		--ink: #ffffff;
		--muted: #b7c2d7;
		--line: rgba(255, 255, 255, 0.18);
		--surface: rgba(255, 255, 255, 0.08);
		--surface-strong: rgba(255, 255, 255, 0.13);
		--soft: #10172a;
		--brand: #38bdf8;
		--brand-dark: #e0f2fe;
		--accent: #f59e0b;
		color: var(--ink);
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
			sans-serif;
		background: var(--soft);
		scroll-behavior: smooth;
	}

	* {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		min-width: 320px;
		background:
			radial-gradient(circle at 15% 5%, rgba(56, 189, 248, 0.22), transparent 34rem),
			linear-gradient(145deg, #10172a 0%, #111827 54%, #0b1020 100%);
	}

	a {
		color: var(--brand-dark);
	}

	.site-header {
		position: sticky;
		top: 0;
		z-index: 10;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		padding: 18px clamp(18px, 4vw, 56px);
		background: rgba(16, 23, 42, 0.84);
		border-bottom: 1px solid var(--line);
		backdrop-filter: blur(16px);
	}

	.brand {
		display: grid;
		gap: 2px;
		text-decoration: none;
	}

	.brand span {
		color: #ffffff;
		font-weight: 900;
	}

	.brand small,
	.muted,
	time {
		color: var(--muted);
	}

	nav {
		display: flex;
		flex-wrap: wrap;
		justify-content: flex-end;
		gap: 14px;
		font-size: 0.95rem;
	}

	nav a {
		color: #ffffff;
		text-decoration: none;
		font-weight: 750;
	}

	.nav-cta {
		padding: 8px 14px;
		border: 1px solid rgba(255, 255, 255, 0.42);
		border-radius: 999px;
	}

	main {
		width: min(1180px, calc(100vw - 32px));
		margin: 0 auto;
	}

	.hero {
		display: grid;
		grid-template-columns: minmax(0, 1.6fr) minmax(280px, 0.8fr);
		gap: 28px;
		align-items: stretch;
		min-height: 72vh;
		padding: 76px 0 48px;
	}

	.hero-content,
	.notice,
	.card,
	.contact-card,
	details {
		background: var(--surface);
		border: 1px solid var(--line);
		border-radius: 30px;
		box-shadow: 0 30px 90px rgba(0, 0, 0, 0.24);
		backdrop-filter: blur(18px);
	}

	.hero-content {
		padding: clamp(28px, 5vw, 56px);
	}

	.notice {
		align-self: stretch;
		padding: 28px;
		border-color: rgba(245, 158, 11, 0.45);
		background: rgba(245, 158, 11, 0.12);
	}

	.eyebrow {
		margin: 0 0 10px;
		color: #7dd3fc;
		font-size: 0.82rem;
		font-weight: 850;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	h1,
	h2,
	h3,
	p {
		margin-top: 0;
	}

	h1 {
		margin-bottom: 10px;
		font-size: clamp(2.5rem, 7vw, 5.4rem);
		line-height: 0.96;
	}

	h2 {
		font-size: clamp(1.9rem, 4vw, 3rem);
		line-height: 1.08;
	}

	h3 {
		margin-bottom: 10px;
		font-size: 1.15rem;
	}

	p,
	li,
	label,
	input,
	textarea {
		font-size: 1rem;
		line-height: 1.65;
	}

	.lead {
		color: var(--brand-dark);
		font-size: clamp(1.2rem, 2.4vw, 1.55rem);
		font-weight: 750;
	}

	.hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 12px;
		margin-top: 28px;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 44px;
		padding: 10px 18px;
		border: 1px solid var(--brand);
		border-radius: 999px;
		font-weight: 800;
		text-decoration: none;
	}

	.button.primary {
		color: #ffffff;
		background: linear-gradient(135deg, #0284c7, #0ea5e9);
	}

	.button.secondary {
		color: #ffffff;
		background: transparent;
		border-color: rgba(255, 255, 255, 0.38);
	}

	.section {
		position: relative;
		padding: 42px 0;
	}

	.anchor-alias {
		position: absolute;
		top: -82px;
	}

	.section-head {
		max-width: 720px;
		margin-bottom: 24px;
	}

	.news-list,
	.service-grid,
	.contact-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 18px;
	}

	.card,
	.contact-card {
		padding: 24px;
	}

	.service-icon {
		display: inline-grid;
		place-items: center;
		width: 44px;
		height: 44px;
		margin-bottom: 18px;
		color: #ffffff;
		background: rgba(56, 189, 248, 0.22);
		border: 1px solid rgba(125, 211, 252, 0.45);
		border-radius: 999px;
		font-weight: 900;
	}

	.split {
		display: grid;
		grid-template-columns: minmax(0, 0.75fr) minmax(0, 1.25fr);
		gap: 28px;
		align-items: start;
	}

	.hours {
		display: grid;
		gap: 10px;
	}

	.hours-row {
		display: grid;
		grid-template-columns: 150px minmax(0, 1fr);
		gap: 16px;
		padding: 16px 0;
		border-bottom: 1px solid var(--line);
	}

	.hours-row h3,
	.hours-row ul {
		margin: 0;
	}

	.hours-row ul,
	.contact-list,
	.team-list {
		padding-left: 18px;
	}

	.info-list,
	.price-list {
		display: grid;
		gap: 12px;
	}

	.info-row,
	.price-row {
		padding: 18px 20px;
		background: var(--surface);
		border: 1px solid var(--line);
		border-radius: 22px;
	}

	.price-row {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 18px;
		align-items: start;
	}

	.price-row p {
		margin-bottom: 0;
		color: var(--muted);
	}

	.price-row span {
		color: #ffffff;
		font-weight: 900;
		white-space: nowrap;
	}

	details {
		padding: 18px 20px;
		margin-bottom: 12px;
	}

	summary {
		cursor: pointer;
		display: flex;
		justify-content: space-between;
		gap: 18px;
		font-weight: 850;
	}

	summary::after {
		content: "+";
		color: var(--brand);
		font-size: 1.35rem;
		line-height: 1;
	}

	details[open] summary::after {
		content: "-";
	}

	address {
		font-style: normal;
		line-height: 1.7;
	}

	form {
		display: grid;
		gap: 14px;
	}

	.form-note {
		margin: 0;
		color: var(--muted);
		font-size: 0.92rem;
		line-height: 1.55;
	}

	.sr-only {
		position: absolute;
		width: 1px;
		height: 1px;
		overflow: hidden;
		clip: rect(0, 0, 0, 0);
		white-space: nowrap;
	}

	label {
		display: grid;
		gap: 6px;
		font-weight: 750;
	}

	input,
	textarea {
		width: 100%;
		padding: 11px 12px;
		border: 1px solid var(--line);
		border-radius: 14px;
		font: inherit;
		color: #ffffff;
		background: rgba(255, 255, 255, 0.08);
	}

	.custom-footer {
		margin-top: 56px;
		color: rgba(255, 255, 255, 0.78);
		background: #0b1020;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
	}

	.footer-container {
		width: min(1180px, calc(100vw - 32px));
		margin: 0 auto;
		padding: 54px 0 28px;
	}

	.footer-grid {
		display: grid;
		grid-template-columns: 1.35fr 0.8fr 0.95fr 0.9fr;
		gap: 34px;
	}

	.footer-brand p {
		max-width: 360px;
		margin: 16px 0 0;
		color: rgba(255, 255, 255, 0.68);
	}

	.footer-logo {
		display: inline-flex;
		align-items: center;
		gap: 10px;
		color: #ffffff;
		font-weight: 850;
		text-decoration: none;
	}

	.footer-logo-icon {
		display: grid;
		place-items: center;
		width: 32px;
		height: 32px;
		color: #ffffff;
		background: #0ea5e9;
		border-radius: 10px;
	}

	.footer-links,
	.footer-insurance {
		display: grid;
		align-content: start;
		gap: 10px;
	}

	.footer-links h4,
	.footer-insurance h4 {
		margin: 0 0 8px;
		color: #ffffff;
		font-size: 1rem;
	}

	.footer-links a,
	.footer-address {
		color: rgba(255, 255, 255, 0.72);
		text-decoration: none;
	}

	.insurance-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 8px;
	}

	.insurance-grid span {
		padding: 8px 10px;
		color: #ffffff;
		background: rgba(255, 255, 255, 0.08);
		border: 1px solid rgba(255, 255, 255, 0.12);
		border-radius: 12px;
		font-size: 0.86rem;
		font-weight: 750;
	}

	.footer-bottom {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 20px;
		margin-top: 38px;
		padding-top: 22px;
		border-top: 1px solid rgba(255, 255, 255, 0.1);
	}

	.footer-copy {
		color: rgba(255, 255, 255, 0.62);
		font-size: 0.92rem;
	}

	.footer-socials {
		display: flex;
		gap: 10px;
	}

	.footer-socials a {
		display: grid;
		place-items: center;
		width: 36px;
		height: 36px;
		color: #ffffff;
		background: rgba(255, 255, 255, 0.08);
