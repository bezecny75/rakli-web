---
import site from '../content/site.json';
import pricing from '../content/pricing.json';

const baseUrl = import.meta.env.BASE_URL;
---

<html lang="cs">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
		<link rel="icon" href={`${baseUrl}favicon.ico`} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={`Ceník placených úkonů ordinace ${site.name}.`} />
		<title>Ceník - {site.name}</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body>
		<header class="page-header">
			<a class="brand" href={baseUrl}>{site.name}</a>
			<a class="back-link" href={`${baseUrl}#kontakt`}>Kontakt</a>
		</header>

		<main>
			<section class="hero">
				<p class="section-label">Placené úkony</p>
				<h1>Ceník</h1>
				<p>Platnost od 01.01.2026. Jedná se o úkony nehrazené zdravotními pojišťovnami.</p>
			</section>

			<section class="price-section">
				<div class="price-list">
					{pricing.map((item) => (
						<div class="price-row">
							<div>
								<strong>{item.title}</strong>
								{item.note && <p>{item.note}</p>}
							</div>
							<span>{item.price}</span>
						</div>
					))}
				</div>

				<a class="button" href={baseUrl}>← Zpět na hlavní stránku</a>
			</section>
		</main>
	</body>
</html>

<style>
	:root {
		--color-primary: #0f4c75;
		--color-primary-light: #e3eff7;
		--color-primary-mid: #1b6ca8;
		--color-accent: #27ae60;
		--color-warm: #f0f4f8;
		--color-text: #1a202c;
		--color-text-muted: #718096;
		--color-border: #e2e8f0;
		--shadow-card: 0 2px 12px rgba(15, 76, 117, 0.10);
		--radius-card: 12px;
		--radius-pill: 50px;
		font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
		color: var(--color-text);
		background: var(--color-warm);
	}

	* { box-sizing: border-box; }
	body { margin: 0; min-width: 320px; background: var(--color-warm); }
	a { color: inherit; text-decoration: none; }
	.page-header { height: 68px; background: white; box-shadow: 0 1px 0 var(--color-border), var(--shadow-card); display: flex; align-items: center; justify-content: space-between; padding: 0 1.5rem; position: sticky; top: 0; z-index: 10; }
	.brand { color: var(--color-primary); font-size: 1.25rem; font-weight: 800; letter-spacing: -0.03em; }
	.back-link { color: var(--color-primary-mid); font-weight: 700; }
	.hero { max-width: 900px; margin: 0 auto; padding: 4rem 1.5rem 2rem; text-align: center; }
	.section-label { margin: 0 0 0.4rem; color: var(--color-primary-mid); font-size: 0.75rem; font-weight: 800; letter-spacing: 0.12em; text-transform: uppercase; }
	h1 { margin: 0; font-size: clamp(2.2rem, 5vw, 3.4rem); letter-spacing: -0.05em; }
	.hero p:not(.section-label) { color: var(--color-text-muted); line-height: 1.7; }
	.price-section { max-width: 900px; margin: 0 auto; padding: 0 1.5rem 4rem; }
	.price-list { border: 1px solid var(--color-border); border-radius: var(--radius-card); overflow: hidden; box-shadow: var(--shadow-card); background: white; }
	.price-row { display: flex; justify-content: space-between; align-items: center; gap: 1rem; padding: 0.85rem 1rem; border-bottom: 1px solid var(--color-border); }
	.price-row:nth-child(even) { background: var(--color-warm); }
	.price-row:last-child { border-bottom: none; }
	.price-row strong { font-weight: 600; }
	.price-row p { margin: 0.2rem 0 0; color: var(--color-text-muted); font-size: 0.86rem; }
	.price-row span { color: var(--color-primary-mid); font-weight: 800; white-space: nowrap; }
	.button { display: inline-flex; margin-top: 1.4rem; border: 2px solid var(--color-primary); color: var(--color-primary); border-radius: var(--radius-pill); padding: 0.8rem 1.6rem; font-weight: 800; background: white; }
	@media (max-width: 560px) {
		.price-row { align-items: flex-start; flex-direction: column; gap: 0.35rem; }
	}
</style>
