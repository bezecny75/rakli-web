---
import site from '../content/site.json';

const baseUrl = import.meta.env.BASE_URL;
---

<html lang="cs">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href={`${baseUrl}favicon.svg`} />
		<link rel="icon" href={`${baseUrl}favicon.ico`} />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="Potvrzení odeslání kontaktního formuláře Rakli s.r.o." />
		<title>Děkujeme za zprávu - {site.name}</title>
	</head>
	<body>
		<main class="thank-you">
			<section class="panel">
				<p class="eyebrow">{site.name}</p>
				<h1>Děkujeme za zprávu</h1>
				<p>
					Formulář byl odeslán. Ordinace se ozve podle provozních možností.
					Akutní zdravotní potíže prosím řešte telefonicky nebo přes záchrannou
					službu.
				</p>
				<a class="button primary" href={baseUrl}>Zpět na web</a>
			</section>
		</main>
	</body>
</html>

<style>
	:root {
		--ink: #ffffff;
		--muted: #b7c2d7;
		--brand: #2ac7b8;
		--brand-dark: #159489;
		--line: rgba(255, 255, 255, 0.18);
		--panel: rgba(10, 17, 31, 0.84);
		font-family:
			Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
			sans-serif;
		color: var(--ink);
		background: #07101f;
	}

	* {
		box-sizing: border-box;
	}

	body {
		margin: 0;
		min-height: 100vh;
		background:
			radial-gradient(circle at 18% 15%, rgba(42, 199, 184, 0.2), transparent 32%),
			linear-gradient(135deg, rgba(4, 12, 24, 0.98), rgba(12, 43, 52, 0.92));
	}

	.thank-you {
		min-height: 100vh;
		display: grid;
		place-items: center;
		padding: 24px;
	}

	.panel {
		width: min(620px, 100%);
		padding: 34px;
		border: 1px solid var(--line);
		border-radius: 28px;
		background: var(--panel);
		box-shadow: 0 26px 80px rgba(0, 0, 0, 0.36);
	}

	.eyebrow {
		margin: 0 0 12px;
		color: var(--brand);
		font-size: 0.78rem;
		font-weight: 850;
		letter-spacing: 0;
		text-transform: uppercase;
	}

	h1 {
		margin: 0 0 14px;
		font-size: clamp(2rem, 4vw, 3.4rem);
		line-height: 1.02;
	}

	p {
		margin: 0 0 24px;
		color: var(--muted);
		line-height: 1.65;
	}

	.button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 46px;
		padding: 13px 18px;
		border-radius: 999px;
		font-weight: 850;
		text-decoration: none;
	}

	.primary {
		color: #06201f;
		background: linear-gradient(135deg, var(--brand), #b8f4e4);
		box-shadow: 0 16px 36px rgba(42, 199, 184, 0.28);
	}
</style>
